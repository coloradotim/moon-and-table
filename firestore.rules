rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserScopedDocument(documentId) {
      return signedIn()
        && (documentId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    function ownsEmailScopedDocument() {
      return signedIn()
        && request.auth.token.email != null
        && resource.data.email == request.auth.token.email;
    }

    function isHouseholdMember(householdId) {
      return signedIn()
        && householdId != null
        && exists(/databases/$(database)/documents/households/$(householdId))
        && (
          request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberUserIds ||
          (
            request.auth.token.email != null &&
            request.auth.token.email in get(/databases/$(database)/documents/households/$(householdId)).data.memberEmails
          )
        );
    }

    function isPublishedFindableRitualPointer() {
      return signedIn()
        && resource.data.schemaVersion == "ritual-db-v1"
        && resource.data.lifecycle.findable == true
        && resource.data.publishedVersionId is string;
    }

    function isFindableRitualPointerForQuery() {
      return signedIn()
        && resource.data.schemaVersion == "ritual-db-v1"
        && resource.data.lifecycle.findable == true;
    }

    function isPublishedFindableRitualVersion(versionId) {
      let pointer = get(/databases/$(database)/documents/rituals/$(resource.data.ritualId));

      return signedIn()
        && resource.data.schemaVersion == "ritual-db-v1"
        && resource.data.versionId == versionId
        && pointer.data.schemaVersion == "ritual-db-v1"
        && pointer.data.lifecycle.findable == true
        && pointer.data.publishedVersionId == versionId;
    }

    function ownsPrivateDocument(documentId) {
      return ownsUserScopedDocument(documentId)
        || ownsEmailScopedDocument()
        || isHouseholdMember(resource.data.householdId);
    }

    function keepsOwnUserScopedDocument() {
      return signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    function keepsOwnPrivateDocument(documentId) {
      return ownsPrivateDocument(documentId)
        && request.resource.data.householdId == resource.data.householdId
        && (
          resource.data.userId == null ||
          request.resource.data.userId == resource.data.userId
        )
        && (
          resource.data.email == null ||
          request.resource.data.email == resource.data.email
        );
    }

    function createsOwnUserScopedDocument() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function requestHouseholdIdMatchesPath(householdId) {
      return !("householdId" in request.resource.data)
        || request.resource.data.householdId == householdId;
    }

    function hasNoForbiddenHouseholdStateKeys() {
      return !request.resource.data.keys().hasAny([
        "birthDate",
        "birthPlace",
        "birthTime",
        "copiedSourceText",
        "email",
        "extractedSourceText",
        "natalPlacements",
        "ocrText",
        "pageImage",
        "pageImages",
        "privateArtifactPath",
        "privateProfile",
        "privateSourceExcerpt",
        "privateSourceText",
        "rawSourceExcerpt",
        "rawSourceText",
        "realName",
        "schedule",
        "sourceExcerpt"
      ]);
    }

    function canWriteHouseholdState(householdId) {
      return isHouseholdMember(householdId)
        && requestHouseholdIdMatchesPath(householdId)
        && hasNoForbiddenHouseholdStateKeys();
    }

    match /households/{householdId} {
      allow read, update, delete: if signedIn()
        && (
          request.auth.uid in resource.data.memberUserIds ||
          request.auth.token.email in resource.data.memberEmails
        );
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.ownerUserId
        && request.auth.uid in request.resource.data.memberUserIds;

      match /ritualFavorites/{ritualId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update: if canWriteHouseholdState(householdId)
          && request.resource.data.ritualId == ritualId;
        allow delete: if isHouseholdMember(householdId);
      }

      match /recommendationInstances/{recommendationInstanceId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update: if canWriteHouseholdState(householdId)
          && request.resource.data.id == recommendationInstanceId
          && request.resource.data.selectedRitualId is string;
        allow delete: if isHouseholdMember(householdId);
      }

      match /ritualInteractionEvents/{eventId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update: if canWriteHouseholdState(householdId)
          && request.resource.data.id == eventId
          && request.resource.data.ritualId is string
          && request.resource.data.eventType is string;
        allow delete: if isHouseholdMember(householdId);
      }

      match /ritualHistory/{eventId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update: if canWriteHouseholdState(householdId)
          && request.resource.data.id == eventId
          && request.resource.data.ritualId is string;
        allow delete: if isHouseholdMember(householdId);
      }
    }

    match /rituals/{ritualId} {
      allow get: if isPublishedFindableRitualPointer();
      allow list: if isFindableRitualPointerForQuery();
      allow create, update, delete: if false;

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /ritualVersions/{versionId} {
      allow get: if isPublishedFindableRitualVersion(versionId);
      allow list, create, update, delete: if false;
    }

    match /sourceRuns/{sourceRunId} {
      allow read, write: if false;
    }

    match /importBatches/{importBatchId} {
      allow read, write: if false;
    }

    match /reviewDecisions/{decisionId} {
      allow read, write: if false;
    }

    match /ritualValidationSnapshots/{snapshotId} {
      allow read, write: if false;
    }

    match /ritualAuditEvents/{eventId} {
      allow read, write: if false;
    }

    match /profileEmailLinks/{linkId} {
      allow read: if ownsEmailScopedDocument()
        || isHouseholdMember(resource.data.householdId);
      allow create, update, delete: if false;
    }

    match /profiles/{profileId} {
      allow read, delete: if ownsPrivateDocument(profileId);
      allow update: if keepsOwnPrivateDocument(profileId);
      allow create: if createsOwnUserScopedDocument();
    }

    match /scheduleConstraints/{constraintId} {
      allow read, delete: if ownsPrivateDocument(constraintId);
      allow update: if keepsOwnPrivateDocument(constraintId);
      allow create: if createsOwnUserScopedDocument();
    }

    match /capacitySettings/{settingId} {
      allow read, delete: if ownsPrivateDocument(settingId);
      allow update: if keepsOwnPrivateDocument(settingId);
      allow create: if createsOwnUserScopedDocument();
    }

    match /briefs/{briefId} {
      allow read, delete: if ownsUserScopedDocument(briefId);
      allow update: if keepsOwnUserScopedDocument();
      allow create: if createsOwnUserScopedDocument();
    }

    match /feedback/{feedbackId} {
      allow read, delete: if ownsUserScopedDocument(feedbackId);
      allow update: if keepsOwnUserScopedDocument();
      allow create: if createsOwnUserScopedDocument();
    }

    match /ritualNotes/{noteId} {
      allow read, delete: if ownsUserScopedDocument(noteId);
      allow update: if keepsOwnUserScopedDocument();
      allow create: if createsOwnUserScopedDocument();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
